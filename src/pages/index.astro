---
import { getCollection, render } from "astro:content";
import Image from "astro/components/Image.astro";
import MaskImage from "@images/mask.png";
// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import Socials from "@components/Socials/Socials.astro";
import Links from "@components/Links/Links.astro";

const bio = await getCollection("bio");

const profile = bio[0];
const { name, avatar, background, blur } = profile.data;
const { Content } = await render(profile);
---

<BaseLayout
	title={`${name} | Making Websites`}
	description={`Modern websites by ${name}. Check what we can do for you.`}
	image={avatar}
>
	<div class="relative min-h-[100lvh]">
		<!-- background image -->
		<div id="background" class="fixed w-screen h-screen top-0 z-0 before:bg-gradient-to-b before:from-transparent before:to-white before:opacity-50">
			<Image class:list={ ['absolute', 'w-screen', 'h-screen', 'top-0', 'object-cover', 'z-2', 'dark:brightness-0' ] } src={MaskImage} alt="" loading="eager" />
			<canvas class:list={ ['absolute', 'w-screen', 'h-screen', 'top-0', 'z-1', 'object-cover', 'opacity-50', 'duration-1000'] } id="background-gradient"></canvas>
			<script>
				const c = document.getElementById("background-gradient") as HTMLCanvasElement;
				const ctx = c.getContext("2d");
				
				// Create linear gradient
				if(!ctx) {
					throw new Error("Failed to get canvas context");
				}
				const grad=ctx.createLinearGradient(0,0, 280,0);
				grad.addColorStop(0, "lightblue");
				grad.addColorStop(0.5, "purple");
				grad.addColorStop(1, "darkblue");
				
				// Fill rectangle with gradient
				ctx.fillStyle = grad;
				ctx.fillRect(0,0, 1200,400);
				setTimeout(() => {
					c.classList.add('opcaity-0')
				}, 1000)
			</script>
		</div>

		<!-- backdrop blur -->

		<!-- content -->
		<section id="profile" class="site-container relative pt-12 text-center md:pt-20">
			<!-- profile image -->
			<div class="mx-auto flex justify-center">
				<figure class="">
					<Image
						src={avatar}
						alt={`${name}'s avatar`}
						width={128}
						densities={[1.5, 2]}
						quality="high"
						loading="eager"
						class="aspect-square max-w-28 rounded-full object-cover"
					/>
				</figure>
			</div>

			<h1 class="mt-4 text-xl sm:text-3xl dark:text-white">{name}</h1>
			
			<div class="markdown-content mt-2 mb-4 text-sm leading-snug text-pretty sm:text-base">
				<Content />
			</div>
		</section>
		<Links />
	</div>
</BaseLayout>
